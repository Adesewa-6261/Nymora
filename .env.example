# Copy this file to ".env" and fill in your values.

# Private key of the wallet you deploy from (export from MetaMask).
# This wallet needs a small amount of Sepolia test ETH for gas.
# NEVER commit the real .env file. NEVER use a wallet with real funds.
PRIVATE_KEY=your_wallet_private_key_here

# OPTIONAL (only needed for contract verification).
# Free API key from https://etherscan.io (Account -> API Keys).
ETHERSCAN_API_KEY=your_etherscan_api_key_here
